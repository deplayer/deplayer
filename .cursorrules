version: "1.0"

environment:
  node:
    required: true
    version: ">=18"
    message: "Node.js version 18 or higher is required"

applications:
  deplayer:
    frontend:
      framework: "react"
      css_framework: "tailwindcss"
      build_tool: "vite"
      state_management: "redux"

rules:
  structure:
    - name: "Components Structure"
      pattern: "src/components/**/*.tsx"
      required: true
      message: "Components must be in src/components directory"

    - name: "Common Components"
      pattern: "src/components/common/**/*.tsx"
      required: true
      message: "Common/reusable components must be in src/components/common"

    - name: "Redux Containers"
      pattern: "src/containers/**/*.tsx"
      required: true
      message: "Redux containers must be in src/containers directory"

    - name: "Redux Sagas"
      pattern: "src/sagas/**/*.ts"
      required: true
      message: "Redux sagas must be in src/sagas directory"

    - name: "Database Schema"
      pattern: "drizzle/**/*.ts"
      required: true
      message: "Database schema and migrations must be in drizzle directory"

  testing:
    - name: "Test Files Location"
      pattern: "src/**/*.spec.tsx"
      required: true
      message: "Test files must be next to implementation files with .spec.tsx extension"

    - name: "Test Matchers"
      pattern: "src/**/*.spec.tsx"
      content_pattern: "getByTitle"
      forbidden: true
      message: "Don't use getByTitle in tests"

  typescript:
    - name: "Strict Mode"
      pattern: "tsconfig.json"
      content_pattern: '"strict": true'
      required: true
      message: "TypeScript strict mode must be enabled"

    - name: "React Imports"
      pattern: "src/**/*.tsx"
      content_pattern: "import React from 'react'"
      forbidden: true
      message: "Don't import React from 'react' in the top level"

  styling:
    - name: "Custom Styles Location"
      pattern: "src/styles/**/*.scss"
      required: true
      message: "Custom styles must be in src/styles directory"

    - name: "Tailwind Config"
      pattern: "tailwind.config.js"
      required: true
      message: "Tailwind configuration file must exist"

  translations:
    - name: "Translation Files"
      pattern: "src/locales/*.json"
      required: true
      message: "Translation files must be in src/locales directory"

    - name: "Translation Component Usage"
      pattern: "src/components/**/*.tsx"
      content_pattern: "<Translate"
      required: true
      message: "Use Translate component for text translations"

ignore_patterns:
  - "node_modules/**"
  - "dist/**"
  - "coverage/**"
  - "*.log"
  - ".env*"

constraints:
  files:
    max_size: "500KB"
    max_line_length: 120
    required:
      - "README.md"
      - ".gitignore"
      - "tsconfig.json"
      - "vite.config.ts"
      - "package.json"

naming_conventions:
  - scope: "components"
    case: "PascalCase"
  - scope: "functions"
    case: "camelCase"
  - scope: "variables"
    case: "camelCase"
  - scope: "constants"
    case: "SCREAMING_SNAKE_CASE"
  - scope: "files"
    case: "PascalCase"
    pattern: "src/components/**/*.tsx"
  - scope: "test_files"
    case: "PascalCase"
    pattern: "src/**/*.spec.tsx"
